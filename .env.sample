# .env.sample — copy to .env and fill in your credentials
#   cp .env.sample .env
#
# .env is git-ignored (see .gitignore).

# --- Jira / Atlassian (mcp-atlassian) ---
JIRA_URL=https://CHANGE_ME.atlassian.net
JIRA_USERNAME=CHANGE_ME@example.com
JIRA_API_TOKEN=CHANGE_ME

# --- GitLab (zereight/gitlab-mcp) ---
GITLAB_PERSONAL_ACCESS_TOKEN=CHANGE_ME
GITLAB_API_URL=https://CHANGE_ME.gitlab.com/api/v4
